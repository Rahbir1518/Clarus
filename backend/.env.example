# Supabase (use service role key for server-side access)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Twilio (used by ElevenLabs for outbound calls + SMS fallback)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# ElevenLabs Conversational AI
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_AGENT_ID=your-elevenlabs-agent-id
ELEVENLABS_PHONE_NUMBER_ID=your-phone-number-id

# Auth0 (for fetching Google OAuth tokens via Management API)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret

# App base URL (used for webhook callback URLs)
APP_BASE_URL=http://localhost:8000
